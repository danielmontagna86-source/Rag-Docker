# Copie este arquivo para .env e preencha com seus valores reais
# cp .env.example .env

# Chave da API do Google Gemini
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui

# Caminho para a pasta raiz dos fontes Protheus (usado pelo bulk_ingest.py)
# Exemplo Windows: C:\Users\SeuUsuario\Documentos\protheus-sistema
# Exemplo Linux:   /home/usuario/protheus-sistema
SOURCE_DIR=C:\caminho\para\seus\fontes\protheus
